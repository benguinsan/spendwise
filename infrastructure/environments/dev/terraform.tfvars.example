aws_region           = "ap-southeast-1"
project_name         = "spendwise"
environment          = "dev"
enable_nat_gateway   = true
create_rds           = false
# Khi create_rds = true: để db_password = "" để tự sinh và lưu Secrets Manager (1 secret, 1 version).
# Hoặc set db_password tạm thời (gitignore tfvars) — vẫn được mirror vào SM.
# db_password_secret_recovery_window_days = 0
# enable_waf                             = false
# waf_enable_cloudwatch_metrics            = false

app_container_port      = 3000
alb_health_check_path   = "/"
# ALB HTTPS: ACM in same region as ALB; validate DNS at your registrar (no Route53 required for API/ALB).
alb_acm_certificate_arn = "arn:aws:acm:<region>:<account-id>:certificate/<certificate-id>"

# Optional: public hosted zone only for Amplify custom domain (add CNAMEs from Amplify console).
# enable_amplify_hosted_zone  = true
# amplify_hosted_zone_name   = "app.dev.example.com"

# Bastion for SSM port forwarding (optional)
create_bastion              = false
bastion_instance_type       = "t3.nano"
bastion_associate_public_ip = true

# Amplify frontend hosting (replace with your Git repo + token)
amplify_repository_url = "https://github.com/<org>/<repo>.git"
amplify_access_token   = "CHANGE_ME"
amplify_branch_name    = "main"
