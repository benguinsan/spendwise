generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RecurringType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum NotificationType {
  BUDGET_ALERT
  GOAL_REACHED
  REMINDER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  cognitoSub String? @unique @map("cognito_sub")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wallets      Wallet[]
  transactions Transaction[]
  categories   Category[]
  budgets      Budget[]
  goals        Goal[]
  tags         Tag[]
  notifications Notification[]
  recurringTransactions RecurringTransaction[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid()) @map("wallet_id")
  name      String
  balance   Float    @default(0)
  currency  String   @default("VND")
  userId    String @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactionsFrom Transaction[] @relation("fromWallet")
  transactionsTo   Transaction[] @relation("toWallet")
  recurringTransactions RecurringTransaction[]

  @@index([userId])
  @@map("wallets")
}

model Category {
  id        String @id @default(uuid()) @map("category_id")
  name      String
  type      TransactionType
  icon      String?
  userId    String? @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]
  recurringTransactions RecurringTransaction[]

  @@unique([userId, name])
  @@index([type])
  @@map("categories")
}

model Transaction {
  id            String @id @default(uuid()) @map("transaction_id")
  amount        Float
  type          TransactionType
  note          String?
  date          DateTime

  userId        String @map("user_id")
  fromWalletId  String? @map("from_wallet_id")
  toWalletId    String? @map("to_wallet_id")
  categoryId    String? @map("category_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromWallet Wallet? @relation("fromWallet", fields: [fromWalletId], references: [id], onDelete: SetNull)
  toWallet   Wallet? @relation("toWallet", fields: [toWalletId], references: [id], onDelete: SetNull)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags TransactionTag[]

  @@index([userId, date])
  @@index([categoryId])
  @@map("transactions")
}

model Budget {
  id         String @id @default(uuid()) @map("budget_id")
  amount     Float
  month      Int
  year       Int
  userId     String @map("user_id")
  categoryId String? @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@map("budgets")
}

model Tag {
  id        String @id @default(uuid())
  name      String
  userId    String @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model TransactionTag {
  transactionId String @map("transaction_id")
  tagId         String @map("tag_id")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  tag         Tag         @relation(fields: [tagId], references: [id])

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

model Goal {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  target              Float
  current             Float    @default(0)
  deadline            DateTime
  notificationSent    Boolean  @default(false) @map("notification_sent")
  userId              String @map("user_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deadline])
  @@map("goals")
}

model RecurringTransaction {
  id         String        @id @default(uuid())
  amount     Float
  type       TransactionType
  note       String?
  interval   RecurringType
  nextDate   DateTime @map("next_date")
  isActive   Boolean       @default(true) @map("is_active")
  userId     String @map("user_id")
  walletId   String @map("wallet_id")
  categoryId String? @map("category_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  wallet   Wallet   @relation(fields: [walletId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, nextDate, isActive])
  @@map("recurring_transactions")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  userId    String @map("user_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@map("notifications")
}